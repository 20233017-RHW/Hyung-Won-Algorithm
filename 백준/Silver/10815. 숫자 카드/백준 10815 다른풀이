#include <iostream>
#include <map>
#include <algorithm>
using namespace std;

int main()
{
	ios_base::sync_with_stdio(0);
	cin.tie(0); cout.tie(0);

	int a;
	map<int, int> m;
	cin >> a;
	for (int i = 0; i < a; i++) {
		int c;
		cin >> c;
		m[c] = 1;
	}
	int b;
	cin >> b;
	for (int i = 0; i < b; i++) {
		int k;
		cin >> k;
		if (m.find(k) == m.end()) {
			cout << "0" << " ";
		}
		else {
			cout << "1" << " ";
		}
	}
	return 0;
}
맵에서 존재하는 find를 사용하는 방법으로도 풀 수 있지만 메모리가 높게나옴.
